 <section class="why-choose-section">
  <h2 class="section-title">Why Parents Choose Us</h2>
  
  <div class="features-container">
    <!-- Feature 1: Organic -->
    <div class="feature-card">
      <div class="icon-wrapper">
        <svg viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
      </div>
      <h3 class="feature-title">Organic</h3>
      <p class="feature-description">GOTS-certified organic cotton, grown without harmful chemicals.</p>
    </div>

    <!-- Feature 2: Safe -->
    <div class="feature-card">
      <div class="icon-wrapper">
        <svg viewBox="0 0 24 24">
          <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
        </svg>
      </div>
      <h3 class="feature-title">Safe</h3>
      <p class="feature-description">Hypoallergenic materials with nickel-free snaps and flat seams.</p>
    </div>

    <!-- Feature 3: Soft Fabrics -->
    <div class="feature-card">
      <div class="icon-wrapper">
        <svg viewBox="0 0 24 24">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
      </div>
      <h3 class="feature-title">Soft Fabrics</h3>
      <p class="feature-description">Pre-washed for extra softness, gentle on the most delicate skin.</p>
    </div>
  </div>
</section>

  <!-- Why Parents Choose Us section -->

    <!-- ========== WHAT PARENTS SAY SECTION ========== -->
    <section class="testimonials-section">
      <h2 class="testimonials-title">What Parents Say</h2>
      
      <div class="testimonials-container">
        <!-- Testimonial 1 -->
        <div class="testimonial-card">
          <div class="stars">★★★★★</div>
          <p class="testimonial-text">"The softest baby clothes we've ever owned. Our daughter practically lives in her petitbloom onesies!"</p>
          <p class="testimonial-author">— Emma L.</p>
        </div>
  
        <!-- Testimonial 2 -->
        <div class="testimonial-card">
          <div class="stars">★★★★★</div>
          <p class="testimonial-text">"Finally found a brand that cares as much about comfort as we do. Worth every penny."</p>
          <p class="testimonial-author">— James & Sarah</p>
        </div>
  
        <!-- Testimonial 3 -->
        <div class="testimonial-card">
          <div class="stars">★★★★★</div>
          <p class="testimonial-text">"The quality is outstanding. After dozens of washes, everything still looks brand new."</p>
          <p class="testimonial-author">— Maria T.</p>
        </div>
      </div>
    </section>
  
    <!-- ========== JOIN OUR FAMILY SECTION ========== -->
    <section class="newsletter-section">
      <h2 class="newsletter-title">Join Our Family</h2>
      <p class="newsletter-subtitle">Get 10% off your first order plus early access to new collections.</p>
      
      <form class="newsletter-form">
        <input type="email" class="email-input" placeholder="your@email.com" required>
        <button type="submit" class="subscribe-btn">Subscribe</button>
      </form>
    </section>
     <!-- ========== FOOTER SECTION ========== -->
  <footer class="footer">
  <div class="footer-container">
    
    <!-- Brand -->
    <div class="footer-brand">
      <h3 class="footer-logo">{{ section.settings.brand_name }}</h3>
      <p class="footer-tagline">{{ section.settings.brand_tagline }}</p>
    </div>

    <!-- Shop Links -->
    <div class="footer-links">
      <h4>SHOP</h4>
      <ul>
        {% for link in linklists[section.settings.shop_links].links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>

    <!-- Company Links -->
    <div class="footer-links">
      <h4>COMPANY</h4>
      <ul>
        {% for link in linklists[section.settings.company_links].links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>

    <!-- Support Links -->
    <div class="footer-links">
      <h4>SUPPORT</h4>
      <ul>
        {% for link in linklists[section.settings.support_links].links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <p>© {{ "now" | date: "%Y" }} {{ section.settings.brand_name }}</p>
  </div>
</footer>
{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "petitbloom"
    },
    {
      "type": "textarea",
      "id": "brand_tagline",
      "label": "Tagline",
      "default": "Gentle, organic clothing for your little ones."
    },
    {
      "type": "link_list",
      "id": "shop_links",
      "label": "Shop Links"
    },
    {
      "type": "link_list",
      "id": "company_links",
      "label": "Company Links"
    },
    {
      "type": "link_list",
      "id": "support_links",
      "label": "Support Links"
    }
  ]
}
{% endschema %}