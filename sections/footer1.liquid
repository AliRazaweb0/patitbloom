 <!-- ========== WHY PARENTS CHOOSE US ========== -->
<section class="why-choose-section">
  <h2 class="section-title">Why Parents Choose Us</h2>
  
  <div class="features-container">

    <div class="feature-card">
      <div class="icon-wrapper">
        <svg viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
        </svg>
      </div>
      <h3 class="feature-title">Organic</h3>
      <p class="feature-description">GOTS-certified organic cotton, grown without harmful chemicals.</p>
    </div>

    <div class="feature-card">
      <div class="icon-wrapper">
        <svg viewBox="0 0 24 24">
          <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5z"/>
        </svg>
      </div>
      <h3 class="feature-title">Safe</h3>
      <p class="feature-description">Hypoallergenic materials with nickel-free snaps and flat seams.</p>
    </div>

    <div class="feature-card">
      <div class="icon-wrapper">
        <svg viewBox="0 0 24 24">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3z"/>
        </svg>
      </div>
      <h3 class="feature-title">Soft Fabrics</h3>
      <p class="feature-description">Pre-washed for extra softness, gentle on delicate skin.</p>
    </div>

  </div>
</section>


<!-- ========== TESTIMONIALS ========== -->
<section class="testimonials-section">
  <h2 class="testimonials-title">What Parents Say</h2>
  
  <div class="testimonials-container">

    <div class="testimonial-card">
      <div class="stars">★★★★★</div>
      <p class="testimonial-text">"The softest baby clothes we've ever owned!"</p>
      <p class="testimonial-author">— Emma L.</p>
    </div>

    <div class="testimonial-card">
      <div class="stars">★★★★★</div>
      <p class="testimonial-text">"Amazing comfort and quality. Worth every penny."</p>
      <p class="testimonial-author">— James & Sarah</p>
    </div>

    <div class="testimonial-card">
      <div class="stars">★★★★★</div>
      <p class="testimonial-text">"Even after many washes, still looks brand new."</p>
      <p class="testimonial-author">— Maria T.</p>
    </div>

  </div>
</section>


<!-- ========== NEWSLETTER ========== -->
<section class="newsletter-section">
  <h2 class="newsletter-title">Join Our Family</h2>
  <p class="newsletter-subtitle">
    Get 10% off your first order + early access to new collections.
  </p>
  
  <form class="newsletter-form">
    <input type="email" class="email-input" placeholder="your@email.com" required>
    <button type="submit" class="subscribe-btn">Subscribe</button>
  </form>
</section>


<!-- ========== FOOTER (SHOPIFY DYNAMIC) ========== -->
<footer class="footer">
  <div class="footer-container">

    <div class="footer-brand">
      <h3 class="footer-logo">{{ section.settings.brand_name }}</h3>
      <p class="footer-tagline">{{ section.settings.brand_tagline }}</p>
    </div>

    <div class="footer-links">
      <h4 class="footer-heading">SHOP</h4>
      <ul>
        {% for link in section.settings.shop_links %}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>

    <div class="footer-links">
      <h4 class="footer-heading">COMPANY</h4>
      <ul>
        {% for link in section.settings.company_links %}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>

    <div class="footer-links">
      <h4 class="footer-heading">SUPPORT</h4>
      <ul>
        {% for link in section.settings.support_links %}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <p class="footer-copyright">
      © {{ "now" | date: "%Y" }} {{ section.settings.brand_name }}. All rights reserved.
    </p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "petitbloom"
    },
    {
      "type": "textarea",
      "id": "brand_tagline",
      "label": "Brand Tagline",
      "default": "Gentle, organic clothing for your little ones. Made with love, designed for comfort."
    },
    {
      "type": "link_list",
      "id": "shop_links",
      "label": "Shop Links",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "company_links",
      "label": "Company Links",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "support_links",
      "label": "Support Links",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Default Footer"
    }
  ]
}
{% endschema %}