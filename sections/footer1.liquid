 <style>
 .why-choose-section {
      background-color: #f5f3f0;
      padding: 80px 20px;
      text-align: center;
    }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 36px;
      font-weight: 400;
      color: #2c2c2c;
      margin-bottom: 50px;
    }

    .features-container {
      max-width: 1000px;
      margin: 0 auto;
      display: flex;
      justify-content: center;
      gap: 30px;
      flex-wrap: wrap;
    }

    .feature-card {
      background-color: #faf8f5;
      border-radius: 20px;
      padding: 40px 30px;
      width: 280px;
      text-align: center;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .feature-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    .icon-wrapper {
      width: 60px;
      height: 60px;
      background-color: #f0e6e6;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }

    .icon-wrapper svg {
      width: 24px;
      height: 24px;
      stroke: #8b6b6b;
      fill: none;
      stroke-width: 1.5;
    }

    .feature-title {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      font-weight: 400;
      color: #2c2c2c;
      margin-bottom: 12px;
    }

    .feature-description {
      font-size: 14px;
      line-height: 1.6;
      color: #888;
      font-weight: 400;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .why-choose-section {
        padding: 60px 20px;
      }

      .section-title {
        font-size: 28px;
      }

      .features-container {
        gap: 20px;
      }

      .feature-card {
        width: 100%;
        max-width: 320px;
      }
    }
 /* <!-- Why Parents Choose Us section --> */
    /* ========== WHAT PARENTS SAY SECTION ========== */
    .testimonials-section {
      background-color: #faf8f5;
      padding: 80px 20px;
      text-align: center;
    }

    .testimonials-title {
      font-family: 'Playfair Display', serif;
      font-size: 36px;
      font-weight: 400;
      color: #3d3d3d;
      margin-bottom: 50px;
    }

    .testimonials-container {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      justify-content: center;
      gap: 25px;
      flex-wrap: wrap;
    }

    .testimonial-card {
      background-color: #f5f3f0;
      border-radius: 16px;
      padding: 30px;
      width: 320px;
      text-align: left;
    }

    .stars {
      color: #a08060;
      font-size: 16px;
      letter-spacing: 2px;
      margin-bottom: 15px;
    }

    .testimonial-text {
      font-size: 14px;
      line-height: 1.7;
      color: #666;
      margin-bottom: 20px;
      font-weight: 400;
    }

    .testimonial-author {
      font-size: 13px;
      color: #888;
      font-weight: 400;
    }

    /* ========== JOIN OUR FAMILY SECTION ========== */
    .newsletter-section {
      background-color: #f0e6e6;
      padding: 80px 20px;
      text-align: center;
    }

    .newsletter-title {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      font-weight: 400;
      color: #3d3d3d;
      margin-bottom: 12px;
    }

    .newsletter-subtitle {
      font-size: 14px;
      color: #888;
      margin-bottom: 35px;
      font-weight: 400;
    }

    .newsletter-form {
      max-width: 450px;
      margin: 0 auto;
      display: flex;
      gap: 12px;
      justify-content: center;
      align-items: center;
    }

    .email-input {
      flex: 1;
      padding: 14px 20px;
      border: none;
      border-radius: 30px;
      background-color: #faf8f5;
      font-size: 14px;
      color: #666;
      outline: none;
      font-family: 'Inter', sans-serif;
    }

    .email-input::placeholder {
      color: #aaa;
    }

    .subscribe-btn {
      padding: 14px 28px;
      border: none;
      border-radius: 30px;
      background-color: #8b6b5c;
      color: #fff;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: background-color 0.3s ease;
      font-family: 'Inter', sans-serif;
    }

    .subscribe-btn:hover {
      background-color: #7a5d50;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .testimonials-section,
      .newsletter-section {
        padding: 60px 20px;
      }

      .testimonials-title {
        font-size: 28px;
      }

      .testimonial-card {
        width: 100%;
        max-width: 350px;
      }

      .newsletter-form {
        flex-direction: column;
        width: 100%;
      }

      .email-input,
      .subscribe-btn {
        width: 100%;
      }
    }
    /* ========== FOOTER SECTION ========== */
    .footer {
      background-color: #f5f3f0;
      padding: 60px 40px 30px;
    }

    .footer-container {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      gap: 60px;
      flex-wrap: wrap;
    }

    /* Brand Column */
    .footer-brand {
      flex: 1;
      min-width: 250px;
    }

    .footer-logo {
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      font-weight: 400;
      color: #3d3d3d;
      margin-bottom: 15px;
    }

    .footer-tagline {
      font-size: 14px;
      line-height: 1.6;
      color: #888;
      font-weight: 400;
    }

    /* Links Columns */
    .footer-links {
      flex: 1;
      min-width: 150px;
    }

    .footer-heading {
      font-size: 13px;
      font-weight: 500;
      color: #3d3d3d;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 20px;
    }

    .footer-links ul {
      list-style: none;
    }

    .footer-links li {
      margin-bottom: 12px;
    }

    .footer-links a {
      text-decoration: none;
      font-size: 14px;
      color: #888;
      transition: color 0.3s ease;
    }

    .footer-links a:hover {
      color: #3d3d3d;
    }

    /* Copyright */
    .footer-bottom {
      max-width: 1200px;
      margin: 50px auto 0;
      padding-top: 30px;
      border-top: 1px solid #e5e0dc;
      text-align: center;
    }

    .footer-copyright {
      font-size: 13px;
      color: #999;
      font-weight: 400;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .footer {
        padding: 40px 20px 30px;
      }

      .footer-container {
        flex-direction: column;
        gap: 40px;
      }

      .footer-brand {
        min-width: 100%;
      }

      .footer-links {
        min-width: 100%;
      }
    }
 </style>
