    /* Section */
    .collection-section {
      padding: 80px 15px;
      /* top bottom + left right max 15px */
      background: #f6f3ef;
    }

    /* Container */
    .container {
      max-width: 1200px;
      margin: auto;
    }

    /* Header */
    .section-header {
      text-align: center;
      margin-bottom: 50px;
    }

    .section-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 36px;
      color: #2d2d2d;
      margin-bottom: 10px;
    }

    .section-header p {
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      color: #8a8a8a;
    }

    /* Grid */
    .collection-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 25px;
    }

    /* Card */
    .card {
      position: relative;
      border-radius: 15px;
      overflow: hidden;
    }

    /* Image */
    .card img {
      width: 100%;
      height: 320px;
      object-fit: cover;
      display: block;
    }

    /* Overlay Box */
    .card-overlay {
      position: absolute;
      bottom: 15px;
      left: 15px;
      right: 15px;
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(8px);
      border-radius: 12px;
      padding: 15px 18px;
    }

    /* Title */
    .card-overlay h3 {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      color: #2d2d2d;
      margin-bottom: 5px;
    }

    /* Subtitle */
    .card-overlay span {
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      color: #7a7a7a;

    }


    .bestsellers-section {
    padding: 80px 20px;
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .section-header {
    margin-bottom: 50px;
  }

  .section-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
    color: #2d2d2d;
    margin-bottom: 10px;
  }

  .section-header p {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #6b6b6b;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
    margin-bottom: 20px;
  }

  /* Hidden products grid */
  .hidden-products {
    display: none;
    margin-top: 25px;
  }

  @media (max-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }

  .product-card {
    text-decoration: none;
    display: block;
    transition: transform 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
  }

  .image-wrapper {
    width: 100%;
    height: 300px;
    overflow: hidden;
    border-radius: 15px;
    margin-bottom: 15px;
    background: #f5f5f5;
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .product-card:hover .image-wrapper img {
    transform: scale(1.05);
  }

  .product-name {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #2d2d2d;
    margin-bottom: 5px;
    font-weight: 500;
  }

  .product-price {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #8b5e3c;
    font-weight: 600;
  }

  .view-all-btn {
    display: inline-block;
    padding: 14px 32px;
    background: transparent;
    color: #2d2d2d;
    border: 2px solid #2d2d2d;
    border-radius: 30px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    margin-top: 20px;
  }

  .view-all-btn:hover {
    background: #2d2d2d;
    color: white;
  }

  /* Smooth show animation */
  .show-products {
    display: grid !important;
    animation: fadeIn 0.5s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

</style>
 <section class="hero">
    <img src="https://cdn.shopify.com/s/files/1/0998/9750/8121/files/imgs.jpg?v=1775724817" alt="baby" class="hero-img" />

    <div class="overlay"></div>

    <div class="hero-content">
      <p class="subheading">SPRING COLLECTION 2026</p>

      <h1>
        Gentle Comfort <br />
        for Little Ones
      </h1>

      <p class="description">
        Thoughtfully crafted organic clothing that wraps your baby in softness from day one.
      </p>

      <div class="buttons">
        <a href="#" class="btn primary">Shop Collection</a>
        <a href="#" class="btn secondary">Our Story</a>
      </div>
    </div>
  </section>
  <!-- End main flex -->


  <!-- collections cards-->
<section class="collection-section">
  <div class="container">
    <div class="section-header">
      <h2>Shop by Category</h2>
      <p>Find the perfect pieces for every stage</p>
    </div>

    <div class="collection-grid">
      {% for collection in collections %}
        {% unless collection.handle == 'frontpage' %}
          <a href="{{ collection.url }}">
            <div class="card">
              <div class="card-image-wrapper">
                {% if collection.image %}
                  <img src="{{ collection.image | img_url: 'large' }}" alt="{{ collection.title }}">
                {% else %}
                  <img src="{{ collection.products.first.featured_image | img_url: 'large' }}" alt="{{ collection.title }}">
                {% endif %}
              </div>
              <div class="card-overlay">
                <h3>{{ collection.title }}</h3>
                <span>{{ collection.description | strip_html | truncatewords: 3 }}</span>
              </div>
            </div>
          </a>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>
  <!-- end collection cards -->



  <!-- All view product section --> 
<section class="bestsellers-section">
  <div class="section-header">
    <h2>Bestsellers</h2>
    <p>Loved by parents, adored by babies</p>
  </div>

  <!-- Pehle 4 Products (Hamesha Visible) -->
  <div class="products-grid" id="initial-products">
    {% for product in collections.all.products limit: 4 %}
      <a href="{{ product.url }}" class="product-card">
        <div class="image-wrapper">
          <img src="{{ product.featured_image | img_url: 'large' }}" alt="{{ product.title }}">
        </div>
        <p class="product-name">{{ product.title }}</p>
        <p class="product-price">{{ product.price | money }}</p>
      </a>
    {% endfor %}
  </div>

  <!-- Baaki Products (Hidden by default) -->
  <div class="products-grid hidden-products" id="more-products" style="display: none;">
    {% for product in collections.all.products offset: 4 %}
      <a href="{{ product.url }}" class="product-card">
        <div class="image-wrapper">
          <img src="{{ product.featured_image | img_url: 'large' }}" alt="{{ product.title }}">
        </div>
        <p class="product-name">{{ product.title }}</p>
        <p class="product-price">{{ product.price | money }}</p>
      </a>
    {% endfor %}
  </div>

  <button onclick="showAllProducts()" class="view-all-btn" id="view-btn">View All Products</button>
</section>
