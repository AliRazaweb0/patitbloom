<style>
    .hero {
  position: relative;
  min-height: 100vh;  /* minimum height */
  height: 100vh;
  width: 100vw;       /* full viewport width */
}

.hero-img {
  position: absolute;
  inset: 0;          /* top:0, right:0, bottom:0, left:0 */
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
}

    /* Soft Overlay */
    .overlay {
      position: absolute;
      inset: 0;
      background: rgba(255, 248, 240, 0.75);
      /* opacity effect */
    }

   .hero {
  position: relative;
  height: 100vh;
  width: 100%;
  overflow: hidden;
  display: flex;
  align-items: center;      /* Vertical center */
  justify-content: flex-start; /* Left align */
}

/* Background Image */
.hero-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  z-index: 0;
}

/* Soft Overlay */
.overlay {
  position: absolute;
  inset: 0;
  background: rgba(255, 248, 240, 0.75);
  z-index: 1;
}

/* Content - Left Side Middle */
.hero-content {
  position: relative;
  max-width: 600px;
  margin-left: 80px;        /* Left spacing */
  z-index: 2;
  /* Agar content ko vertically center karna ho to: */
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Subheading */
.subheading {
  font-family: 'Inter', sans-serif;
  letter-spacing: 3px;
  font-size: 14px;
  color: #a67c52;
  margin-bottom: 15px;
  text-transform: uppercase; /* Optional: better look */
}

/* Heading */
.hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: 64px;
  line-height: 1.1;
  color: #2d2d2d;
  margin-bottom: 20px;
}

/* Description */
.description {
  font-family: 'Inter', sans-serif;
  font-size: 18px;
  color: #6b6b6b;
  line-height: 1.6;
  margin-bottom: 30px;
}

/* Buttons */
.buttons {
  display: flex;
  gap: 15px;
  flex-wrap: wrap;          /* Mobile pe wrap ho jayenge */
}

.btn {
  padding: 14px 28px;
  border-radius: 30px;
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  text-decoration: none;
  transition: 0.3s;
  display: inline-block;
}

/* Primary Button */
.btn.primary {
  background: #8b5e3c;
  color: white;
}

.btn.primary:hover {
  background: #6f4a2f;
}

/* Secondary Button */
.btn.secondary {
  background: #eee;
  color: #333;
}

.btn.secondary:hover {
  background: #ddd;
}

/* Mobile Responsive */
@media (max-width: 768px) {
  .hero-content {
    margin-left: 20px;      /* Mobile pe kam spacing */
    margin-right: 20px;
    max-width: 100%;
  }
  
  .hero h1 {
    font-size: 42px;        /* Mobile pe chhota font */
  }
}

    /* =========================
   Tablet (≤ 1024px)
========================= */
    @media (max-width: 1024px) {

