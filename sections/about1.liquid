<!-- aboutme1 Section Template -->
<section class="aboutme-section" id="aboutme">
    <style>
        .aboutme-section {
            background-color: #faf8f5;
            padding: 0;
        }

        /* Header */
        .aboutme-header {
            background-color: #faf8f5;
            padding: 20px 40px;
            border-bottom: 1px solid #e8e4df;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .aboutme-nav {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .aboutme-logo {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 600;
            color: #2c2c2c;
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        .aboutme-nav-links {
            display: flex;
            gap: 40px;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .aboutme-nav-links a {
            text-decoration: none;
            color: #5a5a5a;
            font-size: 14px;
            font-weight: 400;
            transition: color 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .aboutme-nav-links a:hover {
            color: #8b7355;
        }

        .aboutme-nav-links a.active {
            color: #2c2c2c;
            font-weight: 500;
        }

        .aboutme-cart-icon {
            width: 24px;
            height: 24px;
            cursor: pointer;
        }

        /* Main Content */
        .aboutme-main {
            max-width: 800px;
            margin: 0 auto;
            padding: 80px 20px;
            text-align: center;
        }

        .aboutme-title {
            font-family: 'Playfair Display', serif;
            font-size: 48px;
            color: #2c2c2c;
            margin-bottom: 50px;
            font-weight: 400;
            letter-spacing: -1px;
        }

        .aboutme-story p {
            font-size: 16px;
            line-height: 1.8;
            color: #6b6b6b;
            margin-bottom: 30px;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
            font-family: 'Inter', sans-serif;
        }

        /* Stats Section */
        .aboutme-stats {
            display: flex;
            justify-content: center;
            gap: 80px;
            margin-top: 80px;
            padding: 60px 0;
        }

        .aboutme-stat-item {
            text-align: center;
        }

        .aboutme-stat-number {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            color: #8b7355;
            font-weight: 400;
            margin-bottom: 10px;
        }

        .aboutme-stat-label {
            font-size: 14px;
            color: #6b6b6b;
            font-weight: 400;
            font-family: 'Inter', sans-serif;
        }

        /* Contact Section */
        .aboutme-contact {
            background-color: #f5f2ed;
            padding: 100px 20px;
            margin-top: 60px;
        }

        .aboutme-contact-container {
            max-width: 600px;
            margin: 0 auto;
            text-align: center;
        }

        .aboutme-contact h2 {
            font-family: 'Playfair Display', serif;
            font-size: 36px;
            color: #2c2c2c;
            margin-bottom: 20px;
            font-weight: 400;
        }

        .aboutme-contact > p {
            color: #6b6b6b;
            margin-bottom: 50px;
            font-size: 16px;
            font-family: 'Inter', sans-serif;
        }

        .aboutme-form {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .aboutme-form-group {
            text-align: left;
        }

        .aboutme-form-group label {
            display: block;
            margin-bottom: 8px;
            color: #5a5a5a;
            font-size: 14px;
            font-weight: 500;
            font-family: 'Inter', sans-serif;
        }

        .aboutme-form-group input,
        .aboutme-form-group textarea {
            width: 100%;
            padding: 15px 20px;
            border: 1px solid #d4cfc7;
            background-color: #ffffff;
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            color: #2c2c2c;
            border-radius: 0;
            outline: none;
            transition: border-color 0.3s ease;
        }

        .aboutme-form-group input:focus,
        .aboutme-form-group textarea:focus {
            border-color: #8b7355;
        }

        .aboutme-form-group textarea {
            min-height: 150px;
            resize: vertical;
        }

        .aboutme-submit-btn {
            background-color: #8b7355;
            color: #ffffff;
            padding: 16px 40px;
            border: none;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: background-color 0.3s ease;
            margin-top: 10px;
            letter-spacing: 0.5px;
        }

        .aboutme-submit-btn:hover {
            background-color: #6b5a45;
        }

        .aboutme-contact-info {
            margin-top: 60px;
            display: flex;
            justify-content: center;
            gap: 60px;
            flex-wrap: wrap;
        }

        .aboutme-info-item {
            text-align: center;
        }

        .aboutme-info-item h3 {
            font-family: 'Playfair Display', serif;
            font-size: 18px;
            color: #2c2c2c;
            margin-bottom: 8px;
            font-weight: 400;
        }

        .aboutme-info-item p {
            font-size: 14px;
            color: #6b6b6b;
            font-family: 'Inter', sans-serif;
        }

        /* Mobile Responsive */
        @media screen and (max-width: 768px) {
            .aboutme-header {
                padding: 15px 20px;
            }

            .aboutme-nav-links {
                gap: 20px;
            }

            .aboutme-nav-links a {
                font-size: 13px;
            }

            .aboutme-main {
                padding: 50px 20px;
            }

            .aboutme-title {
                font-size: 36px;
                margin-bottom: 40px;
            }

            .aboutme-story p {
                font-size: 15px;
                line-height: 1.7;
            }

            .aboutme-stats {
                flex-direction: column;
                gap: 40px;
                margin-top: 60px;
                padding: 40px 0;
            }

            .aboutme-stat-number {
                font-size: 36px;
            }

            .aboutme-contact {
                padding: 60px 20px;
            }

            .aboutme-contact h2 {
                font-size: 28px;
            }

            .aboutme-contact-info {
                flex-direction: column;
                gap: 30px;
            }
        }

        @media screen and (max-width: 480px) {
            .aboutme-nav-links {
                gap: 15px;
            }

            .aboutme-title {
                font-size: 32px;
            }

            .aboutme-stat-number {
                font-size: 32px;
            }

            .aboutme-contact h2 {
                font-size: 24px;
            }
        }
    </style>

    <!-- Header -->
    <header class="aboutme-header">
        <nav class="aboutme-nav">
            <a href="#" class="aboutme-logo">petitbloom</a>
            <ul class="aboutme-nav-links">
                <li><a href="#">Home</a></li>
                <li><a href="#">Shop</a></li>
                <li><a href="#" class="active">About</a></li>
                <li><a href="#aboutme-contact">Contact</a></li>
            </ul>
            <svg class="aboutme-cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 6h15l-1.5 9h-12z"></path>
                <circle cx="9" cy="20" r="1"></circle>
                <circle cx="18" cy="20" r="1"></circle>
                <path d="M6 6L5 3H2"></path>
            </svg>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="aboutme-main">
        <h1 class="aboutme-title">Our Story</h1>
        
        <div class="aboutme-story">
            <p>
                petitbloom was born from a simple idea: every baby deserves clothing that's as gentle as a 
                parent's touch. Founded in 2022 by two new mothers frustrated by the lack of truly 
                organic, beautifully designed baby clothing, we set out to create a brand that puts comfort 
                and safety first — without compromising on style.
            </p>
            
            <p>
                Every piece in our collection is made from GOTS-certified organic cotton, sourced from 
                family farms and crafted by artisans who share our commitment to quality. We believe that 
                small choices — like the thread in a seam or the dye in a fabric — make a big difference for 
                little ones.
            </p>
            
            <p>
                From our family to yours, thank you for trusting us to dress your most precious ones.
            </p>
        </div>

        <!-- Stats Section -->
        <div class="aboutme-stats">
            <div class="aboutme-stat-item">
                <div class="aboutme-stat-number">50K+</div>
                <div class="aboutme-stat-label">Happy Families</div>
            </div>
            <div class="aboutme-stat-item">
                <div class="aboutme-stat-number">100%</div>
                <div class="aboutme-stat-label">Organic Materials</div>
            </div>
            <div class="aboutme-stat-item">
                <div class="aboutme-stat-number">0</div>
                <div class="aboutme-stat-label">Harmful Chemicals</div>
            </div>
        </div>
    </main>

    <!-- Contact Section -->
    <section class="aboutme-contact" id="aboutme-contact">
        <div class="aboutme-contact-container">
            <h2>Get in Touch</h2>
            <p>We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>
            
            <form class="aboutme-form">
                <div class="aboutme-form-group">
                    <label for="aboutme-name">Name</label>
                    <input type="text" id="aboutme-name" name="name" required>
                </div>
                
                <div class="aboutme-form-group">
                    <label for="aboutme-email">Email</label>
                    <input type="email" id="aboutme-email" name="email" required>
                </div>
                
                <div class="aboutme-form-group">
                    <label for="aboutme-subject">Subject</label>
                    <input type="text" id="aboutme-subject" name="subject" required>
                </div>
                
                <div class="aboutme-form-group">
                    <label for="aboutme-message">Message</label>
                    <textarea id="aboutme-message" name="message" required></textarea>
                </div>
                
                <button type="submit" class="aboutme-submit-btn">Send Message</button>
            </form>

            <div class="aboutme-contact-info">
                <div class="aboutme-info-item">
                    <h3>Email</h3>
                    <p>hello@petitbloom.com</p>
                </div>
                <div class="aboutme-info-item">
                    <h3>Phone</h3>
                    <p>+1 (555) 123-4567</p>
                </div>
                <div class="aboutme-info-item">
                    <h3>Address</h3>
                    <p>123 Organic Lane, Portland, OR</p>
                </div>
            </div>
        </div>
    </section>
</section>