<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About - petitbloom</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #faf8f5;
            color: #5a5a5a;
            line-height: 1.6;
        }

        /* Header Styles */
        header {
            background-color: #faf8f5;
            padding: 20px 40px;
            border-bottom: 1px solid #e8e4df;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        nav {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 600;
            color: #2c2c2c;
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        .nav-links {
            display: flex;
            gap: 40px;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: #5a5a5a;
            font-size: 14px;
            font-weight: 400;
            transition: color 0.3s ease;
        }

        .nav-links a:hover {
            color: #8b7355;
        }

        .nav-links a.active {
            color: #2c2c2c;
            font-weight: 500;
        }

        .cart-icon {
            width: 24px;
            height: 24px;
            cursor: pointer;
        }

        /* Main Content */
        main {
            max-width: 800px;
            margin: 0 auto;
            padding: 80px 20px;
            text-align: center;
        }

        h1 {
            font-family: 'Playfair Display', serif;
            font-size: 48px;
            color: #2c2c2c;
            margin-bottom: 50px;
            font-weight: 400;
            letter-spacing: -1px;
        }

        .story-section p {
            font-size: 16px;
            line-height: 1.8;
            color: #6b6b6b;
            margin-bottom: 30px;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }

        /* Stats Section */
        .stats-section {
            display: flex;
            justify-content: center;
            gap: 80px;
            margin-top: 80px;
            padding: 60px 0;
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            color: #8b7355;
            font-weight: 400;
            margin-bottom: 10px;
        }

        .stat-label {
            font-size: 14px;
            color: #6b6b6b;
            font-weight: 400;
        }

        /* Contact Section */
        .contact-section {
            background-color: #f5f2ed;
            padding: 100px 20px;
            margin-top: 60px;
        }

        .contact-container {
            max-width: 600px;
            margin: 0 auto;
            text-align: center;
        }

        .contact-section h2 {
            font-family: 'Playfair Display', serif;
            font-size: 36px;
            color: #2c2c2c;
            margin-bottom: 20px;
            font-weight: 400;
        }

        .contact-section > p {
            color: #6b6b6b;
            margin-bottom: 50px;
            font-size: 16px;
        }

        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .form-group {
            text-align: left;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #5a5a5a;
            font-size: 14px;
            font-weight: 500;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 15px 20px;
            border: 1px solid #d4cfc7;
            background-color: #ffffff;
            font-family: 'Inter', sans-serif;
            font-size: 15px;
            color: #2c2c2c;
            border-radius: 0;
            outline: none;
            transition: border-color 0.3s ease;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            border-color: #8b7355;
        }

        .form-group textarea {
            min-height: 150px;
            resize: vertical;
        }

        .submit-btn {
            background-color: #8b7355;
            color: #ffffff;
            padding: 16px 40px;
            border: none;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: background-color 0.3s ease;
            margin-top: 10px;
            letter-spacing: 0.5px;
        }

        .submit-btn:hover {
            background-color: #6b5a45;
        }

        .contact-info {
            margin-top: 60px;
            display: flex;
            justify-content: center;
            gap: 60px;
            flex-wrap: wrap;
        }

        .info-item {
            text-align: center;
        }

        .info-item h3 {
            font-family: 'Playfair Display', serif;
            font-size: 18px;
            color: #2c2c2c;
            margin-bottom: 8px;
            font-weight: 400;
        }

        .info-item p {
            font-size: 14px;
            color: #6b6b6b;
        }

        /* Footer */
        footer {
            background-color: #2c2c2c;
            color: #9a9a9a;
            text-align: center;
            padding: 40px 20px;
            font-size: 14px;
        }

        /* Mobile Responsive */
        @media screen and (max-width: 768px) {
            header {
                padding: 15px 20px;
            }

            .nav-links {
                gap: 20px;
            }

            .nav-links a {
                font-size: 13px;
            }

            main {
                padding: 50px 20px;
            }

            h1 {
                font-size: 36px;
                margin-bottom: 40px;
            }

            .story-section p {
                font-size: 15px;
                line-height: 1.7;
            }

            .stats-section {
                flex-direction: column;
                gap: 40px;
                margin-top: 60px;
                padding: 40px 0;
            }

            .stat-number {
                font-size: 36px;
            }

            .contact-section {
                padding: 60px 20px;
            }

            .contact-section h2 {
                font-size: 28px;
            }

            .contact-info {
                flex-direction: column;
                gap: 30px;
            }
        }

        @media screen and (max-width: 480px) {
            .nav-links {
                gap: 15px;
            }

            h1 {
                font-size: 32px;
            }

            .stat-number {
                font-size: 32px;
            }

            .contact-section h2 {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header>
        <nav>
            <a href="#" class="logo">petitbloom</a>
            <ul class="nav-links">
                <li><a href="#">Home</a></li>
                <li><a href="#">Shop</a></li>
                <li><a href="#" class="active">About</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
            <svg class="cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 6h15l-1.5 9h-12z"></path>
                <circle cx="9" cy="20" r="1"></circle>
                <circle cx="18" cy="20" r="1"></circle>
                <path d="M6 6L5 3H2"></path>
            </svg>
        </nav>
    </header>

    <!-- Main Content -->
    <main>
        <h1>Our Story</h1>
        
        <div class="story-section">
            <p>
                petitbloom was born from a simple idea: every baby deserves clothing that's as gentle as a 
                parent's touch. Founded in 2022 by two new mothers frustrated by the lack of truly 
                organic, beautifully designed baby clothing, we set out to create a brand that puts comfort 
                and safety first — without compromising on style.
            </p>
            
            <p>
                Every piece in our collection is made from GOTS-certified organic cotton, sourced from 
                family farms and crafted by artisans who share our commitment to quality. We believe that 
                small choices — like the thread in a seam or the dye in a fabric — make a big difference for 
                little ones.
            </p>
            
            <p>
                From our family to yours, thank you for trusting us to dress your most precious ones.
            </p>
        </div>

        <!-- Stats Section -->
        <div class="stats-section">
            <div class="stat-item">
                <div class="stat-number">50K+</div>
                <div class="stat-label">Happy Families</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">100%</div>
                <div class="stat-label">Organic Materials</div>
            </div>
            <div class="stat-item">
                <div class="stat-number">0</div>
                <div class="stat-label">Harmful Chemicals</div>
            </div>
        </div>
    </main>

    <!-- Contact Section -->
    <section class="contact-section" id="contact">
        <div class="contact-container">
            <h2>Get in Touch</h2>
            <p>We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>
            
            <form class="contact-form">
                <div class="form-group">
                    <label for="name">Name</label>
                    <input type="text" id="name" name="name" required>
                </div>
                
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required>
                </div>
                
                <div class="form-group">
                    <label for="subject">Subject</label>
                    <input type="text" id="subject" name="subject" required>
                </div>
                
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" required></textarea>
                </div>
                
                <button type="submit" class="submit-btn">Send Message</button>
            </form>

            <div class="contact-info">
                <div class="info-item">
                    <h3>Email</h3>
                    <p>hello@petitbloom.com</p>
                </div>
                <div class="info-item">
                    <h3>Phone</h3>
                    <p>+1 (555) 123-4567</p>
                </div>
                <div class="info-item">
                    <h3>Address</h3>
                    <p>123 Organic Lane, Portland, OR</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2024 petitbloom. All rights reserved.</p>
    </footer>
</body>
</html>