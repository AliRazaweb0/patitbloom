<!-- templates/product.liquid -->

{% if product.handle == 'cloud-sleep-sack' %}
  
  <!-- Custom Product Page - Cloud Sleep Sack Style -->
  <div class="product-page">
    <div class="product-container">
      
      <!-- Left Side - Product Image -->
      <div class="product-image-section">
        <div class="image-wrapper">
          <img src="{{ product.featured_image | img_url: 'large' }}" alt="{{ product.title }}" id="product-image">
        </div>
      </div>

      <!-- Right Side - Product Details -->
      <div class="product-details-section">
        
        <!-- Product Title -->
        <h1 class="product-title">{{ product.title }}</h1>
        
        <!-- Product Price -->
        <div class="product-price">${{ product.price | money_without_currency }}</div>
        
        <!-- 5 Star Rating -->
        <div class="product-rating">
          <span class="stars">★★★★★</span>
          <span class="review-count">({{ product.metafields.reviews.rating_count | default: '1' }} reviews)</span>
        </div>

        <!-- Short Description -->
        <p class="product-short-description">
          {{ product.description | strip_html | truncatewords: 20 }}
        </p>

        <!-- Size Selector -->
        <div class="size-section">
          <label class="section-label">Size</label>
          <div class="size-options">
            {% for variant in product.variants %}
              <button class="size-btn {% if forloop.first %}active{% endif %}" 
                      data-variant-id="{{ variant.id }}"
                      data-size="{{ variant.title }}">
                {{ variant.title }}
              </button>
            {% endfor %}
          </div>
        </div>

        <!-- Quantity Selector -->
        <div class="quantity-section">
          <label class="section-label">Quantity</label>
          <div class="quantity-selector">
            <button class="qty-btn minus" onclick="decreaseQty()">−</button>
            <input type="number" id="quantity" value="1" min="1" class="qty-input">
            <button class="qty-btn plus" onclick="increaseQty()">+</button>
          </div>
        </div>

        <!-- Add to Cart Button -->
        <button class="add-to-cart-btn" onclick="addToCart()">
          Add to Cart — ${{ product.price | money_without_currency }}
        </button>

        <!-- Product Features -->
        <div class="product-features">
          <div class="feature-item">
            <span class="check-icon">✓</span>
            <span>TOG 1.0</span>
          </div>
          <div class="feature-item">
            <span class="check-icon">✓</span>
            <span>Hip-healthy design</span>
          </div>
        </div>

      </div>
    </div>
  </div>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    .product-page {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #faf9f7;
      padding: 40px 20px;
    }

    .product-container {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: start;
    }

    .product-image-section {
      position: sticky;
      top: 20px;
    }

    .image-wrapper {
      background: #b8e6f0;
      border-radius: 20px;
      overflow: hidden;
      aspect-ratio: 1;
    }

    .image-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .product-details-section {
      padding-top: 20px;
    }

    .product-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 42px;
      color: #2c2c2c;
      margin-bottom: 15px;
      font-weight: 400;
      letter-spacing: -0.5px;
    }

    .product-price {
      font-size: 28px;
      color: #2c2c2c;
      margin-bottom: 12px;
      font-weight: 400;
    }

    .product-rating {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 25px;
    }

    .stars {
      color: #8b7355;
      font-size: 16px;
      letter-spacing: 2px;
    }

    .review-count {
      color: #888;
      font-size: 14px;
    }

    .product-short-description {
      color: #666;
      font-size: 16px;
      line-height: 1.6;
      margin-bottom: 30px;
    }

    .size-section {
      margin-bottom: 25px;
    }

    .section-label {
      display: block;
      font-size: 14px;
      color: #2c2c2c;
      margin-bottom: 12px;
      font-weight: 500;
    }

    .size-options {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .size-btn {
      padding: 12px 24px;
      border: 1px solid #ddd;
      background: transparent;
      border-radius: 25px;
      cursor: pointer;
      font-size: 14px;
      color: #666;
      transition: all 0.3s ease;
    }

    .size-btn:hover {
      border-color: #8b7355;
      color: #8b7355;
    }

    .size-btn.active {
      background: #8b7355;
      color: white;
      border-color: #8b7355;
    }

    .quantity-section {
      margin-bottom: 25px;
    }

    .quantity-selector {
      display: flex;
      align-items: center;
      gap: 0;
      border: 1px solid #ddd;
      border-radius: 8px;
      width: fit-content;
    }

    .qty-btn {
      width: 45px;
      height: 45px;
      border: none;
      background: transparent;
      cursor: pointer;
      font-size: 18px;
      color: #666;
      transition: background 0.3s ease;
    }

    .qty-btn:hover {
      background: #f5f5f5;
    }

    .qty-input {
      width: 50px;
      height: 45px;
      border: none;
      text-align: center;
      font-size: 16px;
      color: #2c2c2c;
      -moz-appearance: textfield;
    }

    .qty-input::-webkit-outer-spin-button,
    .qty-input::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    .add-to-cart-btn {
      width: 100%;
      padding: 18px 30px;
      background: #8b7355;
      color: white;
      border: none;
      border-radius: 30px;
      font-size: 16px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.3s ease;
      margin-bottom: 30px;
    }

    .add-to-cart-btn:hover {
      background: #6b5a45;
    }

    .product-features {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .feature-item {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #666;
      font-size: 14px;
    }

    .check-icon {
      color: #8b7355;
      font-weight: bold;
    }

    @media (max-width: 768px) {
      .product-container {
        grid-template-columns: 1fr;
        gap: 30px;
      }

      .product-image-section {
        position: relative;
      }

      .product-title {
        font-size: 32px;
      }
    }
  </style>

  <script>
    // Size selection
    document.querySelectorAll('.size-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
      });
    });

    // Quantity functions
    function increaseQty() {
      var input = document.getElementById('quantity');
      input.value = parseInt(input.value) + 1;
    }

    function decreaseQty() {
      var input = document.getElementById('quantity');
      if (parseInt(input.value) > 1) {
        input.value = parseInt(input.value) - 1;
      }
    }

    // Add to cart function
    function addToCart() {
      var activeBtn = document.querySelector('.size-btn.active');
      var variantId = activeBtn.getAttribute('data-variant-id');
      var quantity = document.getElementById('quantity').value;
      
      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          items: [{
            id: parseInt(variantId),
            quantity: parseInt(quantity)
          }]
        })
      })
      .then(response => response.json())
      .then(data => {
        alert('Added to cart!');
        // window.location.href = '/cart';
      })
      .catch(error => {
        console.error('Error:', error);
      });
    }
  </script>

{% else %}
  
  <!-- Default Product Page (baqi sab products ke liye) -->
  {% section 'product-template' %}
  
{% endif %}