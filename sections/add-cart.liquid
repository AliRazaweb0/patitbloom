{% comment %}
  HOME PAGE - Product Cards Grid
  Ali Jutt Store
{% endcomment %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }} - Home</title>
    {{ content_for_header }}
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #faf9f7; 
            color: #333; 
        }
        
        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background-color: #faf9f7;
            border-bottom: 1px solid #e8e6e3;
        }
        
        .logo {
            font-size: 24px;
            font-weight: 600;
            color: #5c4b37;
            font-family: Georgia, serif;
            text-decoration: none;
        }
        
        .nav { display: flex; gap: 30px; }
        .nav a { text-decoration: none; color: #666; font-size: 14px; }
        .nav a:hover { color: #5c4b37; }
        
        .cart-icon {
            font-size: 20px;
            cursor: pointer;
            position: relative;
            text-decoration: none;
        }
        
        .cart-count {
            position: absolute;
            top: -8px;
            right: -8px;
            background-color: #8b6f47;
            color: white;
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 50%;
        }
        
        /* Hero Section */
        .hero {
            text-align: center;
            padding: 80px 20px;
            background-color: #f5f3f0;
        }
        
        .hero h1 {
            font-size: 48px;
            color: #3d3226;
            font-family: Georgia, serif;
            margin-bottom: 20px;
        }
        
        .hero p {
            font-size: 18px;
            color: #666;
            max-width: 600px;
            margin: 0 auto;
        }
        
        /* Products Section */
        .products-section {
            padding: 60px 50px;
            max-width: 1400px;
            margin: 0 auto;
        }
        
        .section-title {
            font-size: 32px;
            color: #3d3226;
            font-family: Georgia, serif;
            text-align: center;
            margin-bottom: 40px;
        }
        
        /* Product Grid */
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 30px;
        }
        
        /* Product Card */
        .product-card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            transition: transform 0.3s, box-shadow 0.3s;
            text-decoration: none;
            color: inherit;
            display: block;
        }
        
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
        }
        
        .card-image {
            width: 100%;
            height: 320px;
            object-fit: cover;
            background-color: #f0eeeb;
        }
        
        .card-content {
            padding: 20px;
        }
        
        .card-title {
            font-size: 18px;
            font-weight: 500;
            color: #3d3226;
            margin-bottom: 8px;
            font-family: Georgia, serif;
        }
        
        .card-price {
            font-size: 20px;
            color: #8b6f47;
            font-weight: 600;
        }
        
        .card-compare-price {
            font-size: 14px;
            color: #999;
            text-decoration: line-through;
            margin-left: 8px;
        }
        
        .card-badge {
            display: inline-block;
            background-color: #8b6f47;
            color: white;
            font-size: 11px;
            padding: 4px 10px;
            border-radius: 20px;
            margin-top: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        /* Footer */
        .footer {
            background-color: #3d3226;
            color: #ccc;
            padding: 40px 50px;
            text-align: center;
            margin-top: 60px;
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .header { padding: 15px 20px; }
            .nav { display: none; }
            .hero h1 { font-size: 32px; }
            .products-section { padding: 40px 20px; }
            .product-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
            .card-image { height: 200px; }
        }
    </style>
</head>
<body>

    {% comment %} ===== HEADER ===== {% endcomment %}
    <header class="header">
        <a href="/" class="logo">{{ shop.name }}</a>
        <nav class="nav">
            <a href="/">Home</a>
            <a href="/collections/all">Shop</a>
            <a href="/pages/about">About</a>
            <a href="/pages/contact">Contact</a>
        </nav>
        <a href="/cart" class="cart-icon">
            🛒
            {% if cart.item_count > 0 %}
                <span class="cart-count">{{ cart.item_count }}</span>
            {% endif %}
        </a>
    </header>

    {% comment %} ===== HERO ===== {% endcomment %}
    <section class="hero">
        <h1>Welcome to {{ shop.name }}</h1>
        <p>Discover our premium collection of baby essentials, crafted with love and care for your little ones.</p>
    </section>

    {% comment %} ===== PRODUCTS GRID ===== {% endcomment %}
    <section class="products-section">
        <h2 class="section-title">Our Products</h2>
        
        <div class="product-grid">
            {% comment %} Loop through all products {% endcomment %}
            {% for product in collections.all.products limit: 12 %}
                
                <a href="{{ product.url }}" class="product-card">
                    {% comment %} Product Image {% endcomment %}
                    {% if product.featured_image %}
                        <img 
                            src="{{ product.featured_image | image_url: width: 400 }}" 
                            alt="{{ product.title | escape }}"
                            class="card-image"
                            loading="lazy"
                        >
                    {% else %}
                        <div class="card-image" style="display: flex; align-items: center; justify-content: center; color: #999;">
                            No Image
                        </div>
                    {% endif %}
                    
                    <div class="card-content">
                        {% comment %} Product Title {% endcomment %}
                        <h3 class="card-title">{{ product.title }}</h3>
                        
                        {% comment %} Product Price {% endcomment %}
                        <div class="card-price">
                            {{ product.price | money }}
                            {% if product.compare_at_price > product.price %}
                                <span class="card-compare-price">{{ product.compare_at_price | money }}</span>
                            {% endif %}
                        </div>
                        
                        {% comment %} Sale Badge {% endcomment %}
                        {% if product.compare_at_price > product.price %}
                            <span class="card-badge">Sale</span>
                        {% endif %}
                        
                        {% comment %} New Badge {% endcomment %}
                        {% if product.tags contains 'new' %}
                            <span class="card-badge" style="background-color: #4a7c59;">New</span>
                        {% endif %}
                    </div>
                </a>
                
            {% else %}
                {% comment %} No products found {% endcomment %}
                <div style="grid-column: 1/-1; text-align: center; padding: 60px; color: #666;">
                    <p>No products found. Add some products to your store!</p>
                </div>
            {% endfor %}
        </div>
    </section>

    {% comment %} ===== FOOTER ===== {% endcomment %}
    <footer class="footer">
        <p>&copy; {{ "now" | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
    </footer>

</body>
</html>