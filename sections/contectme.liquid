 <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background-color: #faf8f5;
            color: #4a4a4a;
            line-height: 1.6;
        }


        .cart-icon {
            width: 24px;
            height: 24px;
            cursor: pointer;
        }

        /* Main Content */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 80px 60px;
        }

        .header {
            text-align: center;
            margin-bottom: 60px;
        }

        .header h1 {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 48px;
            font-weight: 400;
            color: #2c2c2c;
            margin-bottom: 10px;
            letter-spacing: -1px;
        }

        .header p {
            color: #9a9a9a;
            font-size: 16px;
            font-weight: 300;
        }

        /* Contact Layout */
        .contact-wrapper {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: start;
        }

        /* Left Side - Contact Info */
        .contact-info {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .info-item {
            display: flex;
            align-items: flex-start;
            gap: 15px;
        }

        .icon-circle {
            width: 40px;
            height: 40px;
            background-color: #f4e6e6;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .icon-circle svg {
            width: 18px;
            height: 18px;
            color: #8b6b6b;
        }

        .info-content h3 {
            font-size: 14px;
            font-weight: 600;
            color: #2c2c2c;
            margin-bottom: 4px;
        }

        .info-content p {
            font-size: 14px;
            color: #7a7a7a;
            font-weight: 400;
        }

        /* Right Side - Form */
        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .form-group {
            position: relative;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 16px 20px;
            border: 1px solid #e8e0d8;
            border-radius: 8px;
            background-color: #f5f0eb;
            font-size: 14px;
            color: #4a4a4a;
            transition: all 0.3s ease;
            font-family: inherit;
        }

        .form-group input::placeholder,
        .form-group textarea::placeholder {
            color: #a0a0a0;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #d4c4b8;
            background-color: #faf8f5;
        }

        .form-group textarea {
            min-height: 140px;
            resize: vertical;
        }

        .submit-btn {
            align-self: flex-start;
            background-color: #8b6b5c;
            color: white;
            border: none;
            padding: 16px 32px;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

        .submit-btn:hover {
            background-color: #6b5145;
            transform: translateY(-2px);
        }

        /* Responsive */
        @media (max-width: 768px) {
            nav {
                padding: 20px 30px;
            }

            .nav-links {
                gap: 20px;
            }

            .container {
                padding: 60px 30px;
            }

            .header h1 {
                font-size: 36px;
            }

            .contact-wrapper {
                grid-template-columns: 1fr;
                gap: 50px;
            }
        }
    </style>
</head>
<body>

    <!-- Navigation -->
   

    <!-- Main Content -->
    <div class="container">
        <div class="header">
            <h1>Get in Touch</h1>
            <p>We'd love to hear from you</p>
        </div>

        <div class="contact-wrapper">
            <!-- Left Side: Contact Info -->
            <div class="contact-info">
                <div class="info-item">
                    <div class="icon-circle">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                            <polyline points="22,6 12,13 2,6"></polyline>
                        </svg>
                    </div>
                    <div class="info-content">
                        <h3>Email</h3>
                        <p>alisest78@gmail.com</p>
                    </div>
                </div>

                <div class="info-item">
                    <div class="icon-circle">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                            <circle cx="12" cy="10" r="3"></circle>
                        </svg>
                    </div>
                    <div class="info-content">
                        <h3>Studio</h3>
                        <p>Copenhagen, Denmark</p>
                    </div>
                </div>

                <div class="info-item">
                    <div class="icon-circle">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                    </div>
                    <div class="info-content">
                        <h3>Hours</h3>
                        <p>Mon-Fri, 9am-5pm CET</p>
                    </div>
                </div>
            </div>

            <!-- Right Side: Contact Form -->
            <form class="contact-form">
                <div class="form-group">
                    <input type="text" placeholder="Your name" required>
                </div>
                <div class="form-group">
                    <input type="email" placeholder="your@email.com" required>
                </div>
                <div class="form-group">
                    <textarea placeholder="Your message..." required></textarea>
                </div>
                <button type="submit" class="submit-btn">Send Message</button>
            </form>
        </div>
    </div>
